# LM Studio configuration
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=chandra-ocr-2
LMSTUDIO_API_KEY=

# OCR Híbrido
OCR_MODE=legacy
CLASSIC_OCR_ENGINE=tesseract
ENABLE_PADDLE_FALLBACK=false
ENABLE_GLM_FALLBACK=true
OCR_LANGS=por+eng
QUALITY_THRESHOLD_ACCEPT=0.70
QUALITY_THRESHOLD_RETRY=0.40
MAX_PARALLEL_PAGES=2
OCR_TIMEOUT_SECONDS=120
ENABLE_PAGE_LEVEL_FALLBACK=true
KEEP_INTERMEDIATE_FILES=false
